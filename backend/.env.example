# ─── Memoria AI Backend ─── Environment Variables ───
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ─── Anthropic (Claude) ─────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Groq (Testing / Fast inference) ────────────────
# Set AI_PROVIDER=groq to use Groq instead of Claude
AI_PROVIDER=anthropic
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Supabase ────────────────────────────────────────
# Project URL (without /rest/v1/ suffix)
# Found at: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (server-side only — NEVER expose to frontend)
# Found at: https://supabase.com/dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Anon/public key (safe for frontend — used for auth)
# Found at: https://supabase.com/dashboard → Project Settings → API → anon/public
SUPABASE_ANON_KEY=eyJ...your-anon-key

# JWT secret for verifying auth tokens server-side
# Found at: https://supabase.com/dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Future: Voyage AI (Phase 4) ────────────────────
# VOYAGE_API_KEY=your-voyage-api-key

# ─── Future: Redis/Upstash (Phase 7) ────────────────
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_TOKEN=your-token
